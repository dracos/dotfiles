[user]
	name = Matthew Somerville
	email = matthew@mysociety.org

[alias]
	pf = push --force-with-lease
	s = status -sb
	lg = log --graph --abbrev-commit --date=relative --pretty='%C(auto)%h%d%Creset %s %Cgreen(%ar)%Creset %C(blue)<%an>%Creset'
	lgs = log --oneline --graph
	dc = diff --cached
	la = log --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cblue(%an)%Creset' --decorate --numstat

[rerere]
	enabled = true

[rebase]
	autosquash = true
[core]
	excludesFile = ~/.gitignore
